!(test (parse "A") A)
!(test (parse "(R A B)") (R A B))
!(test (parse "(R A (S B C))") (R A (S B C)))
!(test (parse "(* 2 21)") (quote (* 2 21)))
!(test (parse "\"42\"") "42")
!(test (parse (repr "C:\\Users\\bob")) "C:\\Users\\bob")
!(test (parse (repr "say \"hi\"")) "say \"hi\"")
!(test (parse (repr "a\\nb")) "a\\nb")
